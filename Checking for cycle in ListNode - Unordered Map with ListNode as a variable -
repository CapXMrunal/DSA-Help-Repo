/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    bool hasCycle(ListNode *head) {
        unordered_map<ListNode*,int> mymap;
        while(head)
        {
            if(mymap[head]==1)
            {
                return true;
            }
            mymap[head] = 1;
            head = head->next;
        }
        return false;
    }    
};
