/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    bool hasCycle(ListNode *head) {
        unordered_map<ListNode*,int> mymap;
        while(head)
        {
            if(mymap[head]==1)
            {
                return true;
            }
            mymap[head] = 1;
            head = head->next;
        }
        return false;
    }    
};

////////Using Floyds Cycle detection
class Solution {
public:
    bool hasCycle(ListNode *head) {
        //checking for cycle using Flyods Cycle detection of tortoise and hare algo
        if(!head) return false;
        ListNode* tor = head;
        ListNode* hare = head->next;
        while (hare && hare->next)
        {
            if(tor == hare)
            return true;

            tor = tor->next;
            hare = hare->next->next;
        }
        return false;
    }    
};
