/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        if(!(head)) return nullptr;
        if(k==0) return head; 
        int node = 0;
        ListNode* overhead = head;
        while(head->next)
        {
            node++;
            head = head->next;
        }
        node++;
        node = node-(k%node);
        head->next = overhead;
        ListNode* ans;
        while(node>1)
        {
            overhead = overhead->next;
            node--;
        } 
        ans = overhead->next;
        overhead->next = nullptr;
        return ans;
    }
};
