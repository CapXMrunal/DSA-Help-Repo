class Solution {
public:
    int maxArea(vector<int>& height) {
        int maxarea=0;
        int s;
        int left=0,right=height.size()-1;
        while(left<right) {
            maxarea= max(min(height[left],height[right])*(right-left),maxarea);
            if(height[left]>height[right]) right--;
            else left++;
        }
        return maxarea;
    }
};
