class Solution {
public:
    int change(int amount, vector<int>& coins) {
        // Use unsigned long long to prevent overflow during intermediate DP steps
        // The final answer is guaranteed to fit in a 32-bit int, 
        // but intermediate paths can exceed it.
        vector<unsigned long long> dp(amount + 1, 0);
        dp[0] = 1;
        
        for (int coin : coins) {
            for (int j = coin; j <= amount; j++) {
                dp[j] += dp[j - coin];
            }
        }

        // Cast back to int as required by the function signature
        return (int)dp[amount];
    }
};
